{
  "$schema": "https://haloforge.dev/schemas/plugin/v1.json",
  "id": "dev.haloforge.hello",
  "name": "Hello World",
  "version": "0.2.2",
  "description": "Minimal demo plugin: injects a greeting badge into the DevKit toolbar using the public plugin SDK.",
  "long_description": "Demonstrates Level 2 slot injection, public host navigation/theme hooks, and a simple hello_greet IPC command without relying on private HaloForge bridge APIs.",
  "author": "HaloForge Team",
  "license": "MIT",
  "keywords": ["demo", "hello", "slot"],
  "icon": "assets/icon.png",

  "compatibility": {
    "min_app_version": "0.8.0",
    "min_host_api_version": "0.2.10",
    "platforms": ["windows", "macos", "linux"]
  },

  "capability_levels": [2],
  "host_capabilities": ["navigation", "theme_read"],

  "integration": {
    "level2": {
      "slots": ["devkit.toolbar"]
    }
  },

  "entry": {
    "native": {
      "macos_arm64":    "native/aarch64-apple-darwin.dylib",
      "macos_x64":      "native/x86_64-apple-darwin.dylib",
      "windows_x64":    "native/x86_64-pc-windows-msvc.dll",
      "windows_arm64":  "native/aarch64-pc-windows-msvc.dll",
      "linux_x64":      "native/x86_64-unknown-linux-gnu.so",
      "linux_arm64":    "native/aarch64-unknown-linux-gnu.so"
    },
    "frontend": "frontend/index.js"
  },

  "permissions": [
    { "type": "ipc_register" },
    { "type": "host_navigation" },
    { "type": "host_theme_read" }
  ],

  "commands": [
    { "id": "hello_greet", "description": "Returns a greeting message" }
  ]
}
