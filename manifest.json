{
  "$schema": "https://haloforge.dev/schemas/plugin/v1.json",
  "id": "dev.haloforge.hello",
  "name": "Hello World",
  "version": "0.1.0",
  "description": "Minimal demo plugin: injects a greeting badge into the DevKit toolbar (Level 2 slot example).",
  "long_description": "Demonstrates Level 2 slot injection. Adds a small greeting widget to the devkit.toolbar slot and exposes a hello_greet IPC command.",
  "author": "HaloForge Team",
  "license": "MIT",
  "keywords": ["demo", "hello", "slot"],
  "icon": "assets/icon.png",

  "compatibility": {
    "min_app_version": "1.0.0",
    "platforms": ["windows", "macos", "linux"]
  },

  "capability_levels": [2],

  "integration": {
    "level2": {
      "slots": ["devkit.toolbar"]
    }
  },

  "entry": {
    "native": {
      "macos_arm64":    "native/aarch64-apple-darwin.dylib",
      "macos_x64":      "native/x86_64-apple-darwin.dylib",
      "windows_x64":    "native/x86_64-pc-windows-msvc.dll",
      "windows_arm64":  "native/aarch64-pc-windows-msvc.dll",
      "linux_x64":      "native/x86_64-unknown-linux-gnu.so",
      "linux_arm64":    "native/aarch64-unknown-linux-gnu.so"
    },
    "frontend": "frontend/index.js"
  },

  "permissions": [
    { "type": "ipc_register" }
  ],

  "commands": [
    { "id": "hello_greet", "description": "Returns a greeting message" }
  ]
}
